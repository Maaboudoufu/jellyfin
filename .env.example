# System — replace PUID/PGID with your `id` output, DATA_ROOT with this folder's absolute path
PUID=1000
PGID=1000
TZ=America/Los_Angeles
DATA_ROOT=/absolute/path/to/this/folder

# VPN — fill from your provider's WireGuard config
VPN_SERVICE_PROVIDER=mullvad
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=your_private_key_here
WIREGUARD_ADDRESSES=10.64.0.2/32
SERVER_COUNTRIES=Netherlands
# Port forwarding (Proton, PIA, AirVPN only — NordVPN not supported)
# VPN_PORT_FORWARDING=on
# VPN_PORT_FORWARDING_PROVIDER=protonvpn

# If using NordVPN — replace the VPN block above with this one.
# Get the private key from my.nordaccount.com → Manual Setup; extract it from the access
# token (see qdm12/gluetun-wiki → providers/nordvpn). WIREGUARD_ADDRESSES is not required.
# VPN_SERVICE_PROVIDER=nordvpn
# VPN_TYPE=wireguard
# WIREGUARD_PRIVATE_KEY=your_nordvpn_wireguard_private_key
# SERVER_COUNTRIES=Netherlands
# Optional: SERVER_REGIONS, SERVER_CITIES, SERVER_CATEGORIES

# Your LAN subnet — find with: ip route | grep default
LAN_SUBNET=192.168.1.0/24
