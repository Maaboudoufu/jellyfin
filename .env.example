# System — replace PUID/PGID with your `id` output, DATA_ROOT with this folder's absolute path
PUID=1000
PGID=1000
TZ=America/Los_Angeles
DATA_ROOT=/absolute/path/to/this/folder

# VPN — fill from your provider's WireGuard config
VPN_SERVICE_PROVIDER=mullvad
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=your_private_key_here
WIREGUARD_ADDRESSES=10.64.0.2/32
SERVER_COUNTRIES=Netherlands

# Your LAN subnet — find with: ip route | grep default
LAN_SUBNET=192.168.1.0/24
